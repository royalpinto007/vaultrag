# Postgres (docker-compose brings this up locally)
DATABASE_URL=postgresql://vaultrag:vaultrag@localhost:5433/vaultrag

# Embeddings: "local" (sentence-transformers, free, no key) or "fake" (deterministic, for tests)
EMBEDDER=local
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM for answer generation: "groq" or "fake"
LLM=groq
GROQ_API_KEY=your-key-here
GROQ_MODEL=llama-3.3-70b-versatile
